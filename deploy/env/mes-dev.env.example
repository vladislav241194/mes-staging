# Copy to /etc/mes/mes-dev.env on the VM and edit values.
NODE_ENV=production
APP_ENV=dev
HOST=127.0.0.1
PORT=4174
APP_BASE_URL=https://mes-dev.example.ru

MES_SHARED_STATE_DIR=/srv/mes/dev/shared-state
MES_BACKUP_DIR=/srv/mes/dev/backups
MES_AUDIT_LOG_PATH=/srv/mes/dev/audit/audit.log

MES_ALLOW_DESTRUCTIVE_ACTIONS=true
MES_ENABLE_WORKFLOW_PRESET_RESTORE=true
MES_BACKUP_BEFORE_SHARED_STATE_WRITE=false
BACKUP_RETENTION_DAYS=30
