# Replace server_name values, install TLS, then include from nginx sites-enabled.

upstream mes_dev {
  server 127.0.0.1:4174;
}

upstream mes_user_testing {
  server 127.0.0.1:4175;
}

server {
  listen 80;
  server_name mes-dev.example.ru;

  location / {
    proxy_pass http://mes_dev;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
  }
}

server {
  listen 80;
  server_name mes-test.example.ru;

  location / {
    proxy_pass http://mes_user_testing;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
  }
}
