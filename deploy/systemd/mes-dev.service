[Unit]
Description=MES Dev Preview
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/srv/mes/dev/app
EnvironmentFile=/etc/mes/mes-dev.env
ExecStartPre=/usr/bin/npm run server:preflight
ExecStart=/usr/bin/npm run preview
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/srv/mes/dev

[Install]
WantedBy=multi-user.target
